{
  "manifest_version": 3,
  "name": "ModHeader Clone",
  "version": "1.0.0",
  "description": "A simple clone of ModHeader to modify request and response headers and filter by URL regexes.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ModHeader Clone",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
